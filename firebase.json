{
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "site": "crmcgill",
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/admin",
        "destination": "/Costa Rica Trip Hub.html"
      },
      {
        "source": "/admin/**",
        "destination": "/Costa Rica Trip Hub.html"
      },
      {
        "source": "/staff",
        "destination": "/Costa Rica Trip Hub.html"
      },
      {
        "source": "**",
        "destination": "/student.html"
      }
    ]
  }
}
